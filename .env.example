# Root environment example for Keycloak setup scripts
# Copy to .env and adjust as needed for local development.

# Keycloak server/admin access used by setup scripts
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123

# Realm/client defaults used by scripts/setup-keycloak.js
KEYCLOAK_REALM=demo-realm
KEYCLOAK_CLIENT_ID=web-app
KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_SSL_REQUIRED=none
APP_BASE_URL=http://localhost:3000
# Login mode for demo realm setup:
# - multi-option: passkey + username/password + optional social IdPs (default)
# - passkey-only: passkey-only login in browser flow
KEYCLOAK_LOGIN_MODE=multi-option

# Optional social identity provider credentials used by scripts/setup-keycloak.js
# If these values are not provided, social providers are skipped.
GOOGLE_IDP_CLIENT_ID=
GOOGLE_IDP_CLIENT_SECRET=
APPLE_IDP_CLIENT_ID=
APPLE_IDP_CLIENT_SECRET=

# WebAuthn Passwordless policy overrides used by:
# - scripts/setup-keycloak.js
# - scripts/setup-passkey-realm.js
WEBAUTHN_PASSWORDLESS_RP_ID=localhost
WEBAUTHN_PASSWORDLESS_RP_NAME=Mac App Dev
WEBAUTHN_PASSWORDLESS_ORIGIN=http://localhost:8080
WEBAUTHN_PASSWORDLESS_USER_VERIFICATION=preferred
WEBAUTHN_PASSWORDLESS_ATTESTATION=none

# Reverse proxy and public host settings for VM deploymentsFor
ACME_EMAIL=admin@sammatthews.nz
KEYCLOAK_HOSTNAME=auth.sammatthews.nz
KEYCLOAK_HOSTNAME_STRICT=true
REACT_APP_API_URL=https://api.sammatthews.nz
REACT_APP_KEYCLOAK_URL=https://auth.sammatthews.nz
APP_BASE_URL=https://app.sammatthews.nz
APP_CORS_ORIGINS=https://app.sammatthews.nz,http://localhost:3000
KEYCLOAK_ISSUER_URLS=https://auth.sammatthews.nz/realms/demo-realm,http://localhost:8080/realms/demo-realm,http://keycloak:8080/realms/demo-realm
KEYCLOAK_ACCEPTED_CLIENT_IDS=web-app
