# Root environment example for Keycloak setup scripts
# Copy to .env and adjust as needed for local development.

# Keycloak server/admin access used by setup scripts
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123

# Realm/client defaults used by scripts/setup-keycloak.js
KEYCLOAK_REALM=demo-realm
KEYCLOAK_CLIENT_ID=web-app

# WebAuthn Passwordless policy overrides used by:
# - scripts/setup-keycloak.js
# - scripts/setup-passkey-realm.js
WEBAUTHN_PASSWORDLESS_RP_ID=localhost
WEBAUTHN_PASSWORDLESS_RP_NAME=Mac App Dev
WEBAUTHN_PASSWORDLESS_ORIGIN=http://localhost:8080
WEBAUTHN_PASSWORDLESS_USER_VERIFICATION=preferred
WEBAUTHN_PASSWORDLESS_ATTESTATION=none
